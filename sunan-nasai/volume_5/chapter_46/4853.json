  "language": {
    "ar": {
      "text": "أَخْبَرَنَا عَمْرُو بْنُ عَلِيٍّ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا يَزِيدُ بْنُ زُرَيْعٍ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا سَعِيدٌ، ‏‏‏‏‏‏عَنْ قَتَادَةَ، ‏‏‏‏‏‏عَنْ عِكْرِمَةَ، ‏‏‏‏‏‏عَنِ ابْنِ عَبَّاسٍ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ الْأَصَابِعُ عَشْرٌ عَشْرٌ ."
    },
    "en": {
      "narrator": "",
      "text": "It was narrated that Ibn 'abbas said: The (Diyah for) fingers are ten each."
    },
    "ur": {
      "narrator": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں:",
      "text": "انگلیاں یعنی ان کی دیت دس دس اونٹ ہے۔"
    },
