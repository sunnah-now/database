  "language": {
    "ar": {
      "text": "أَخْبَرَنَا إِسْحَاق بْنُ إِبْرَاهِيمَ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا مُعَاذُ بْنُ هِشَامٍ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنِي أَبِي، ‏‏‏‏‏‏عَنْ قَتَادَةَ، ‏‏‏‏‏‏عَنِ الْحَسَنِ، ‏‏‏‏‏‏عَنْ أَبِي هُرَيْرَةَ، ‏‏‏‏‏‏نَحْوَهُ، ‏‏‏‏‏‏وَلَمْ يَرْفَعْهُ."
    },
    "en": {
      "narrator": "",
      "text": "Narrated from Abu Hurairah: A similar report was narrated from Abu Hurairah, but was not attributed to the Prophet"
    },
    "ur": {
      "narrator": "اس سند سے بھی",
      "text": "ابوہریرہ رضی اللہ عنہ سے اسی طرح مروی ہے لیکن یہ مرفوع نہیں ہے۔"
    },
