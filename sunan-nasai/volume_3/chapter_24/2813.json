  "language": {
    "ar": {
      "text": "أَخْبَرَنَا بِشْرُ بْنُ خَالِدٍ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ أَنْبَأَنَا غُنْدَرٌ، ‏‏‏‏‏‏عَنْ شُعْبَةَ، ‏‏‏‏‏‏عَنْ سُلَيْمَانَ، ‏‏‏‏‏‏عَنْ إِبْرَاهِيمَ التَّيْمِيِّ، ‏‏‏‏‏‏عَنْ أَبِيهِ، ‏‏‏‏‏‏عَنْ أَبِي ذَرٍّ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ كَانَتِ الْمُتْعَةُ رُخْصَةً لَنَا ."
    },
    "en": {
      "narrator": "",
      "text": "It was narrated that Abu Dharr said: Tamattu was just for us."
    },
    "ur": {
      "narrator": "ابوذر رضی الله عنہ کہتے ہیں کہ",
      "text": "متعہ کی رخصت ہمارے لیے خاص تھی۔"
    },
