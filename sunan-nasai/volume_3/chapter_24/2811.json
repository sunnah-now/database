  "language": {
    "ar": {
      "text": "أَخْبَرَنَا عَمْرُو بْنُ يَزِيدَ، ‏‏‏‏‏‏عَنْ عَبْدِ الرَّحْمَنِ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا سُفْيَانُ، ‏‏‏‏‏‏عَنْ الْأَعْمَشِ،‏‏‏‏ وَعَيَّاشٌ الْعَامِرِيُّ، ‏‏‏‏‏‏عَنْ إِبْرَاهِيمَ التَّيْمِيِّ، ‏‏‏‏‏‏عَنْ أَبِيهِ، ‏‏‏‏‏‏عَنْ أَبِي ذَرٍّ، ‏‏‏‏‏‏فِي مُتْعَةِ الْحَجِّ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ كَانَتْ لَنَا رُخْصَةً ."
    },
    "en": {
      "narrator": "",
      "text": "It was narrated that Abu Dharr said concerning Tamattu in Hajj: it was only for us."
    },
    "ur": {
      "narrator": "ابوذر رضی الله عنہ سے حج کے متعہ کے سلسلہ میں روایت ہے، وہ کہتے ہیں کہ",
      "text": "یہ ہمارے لیے رخصت تھی۔"
    },
    "al": {
      "text": ""
    }
  }
