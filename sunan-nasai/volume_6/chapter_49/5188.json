  "language": {
    "ar": {
      "text": "أَخْبَرَنَا قُتَيْبَةُ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ أَخْبَرَنَا حَمَّادٌ، ‏‏‏‏‏‏عَنْ أَيُّوبَ، ‏‏‏‏‏‏عَنْ مُحَمَّدٍ، ‏‏‏‏‏‏عَنْ عَبِيدَةَ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ نَهَى عَنْ مَيَاثِرِ الْأُرْجُوَانِ، ‏‏‏‏‏‏وَخَوَاتِيمِ الذَّهَبِ ."
    },
    "en": {
      "narrator": "",
      "text": "It was narrated that 'Abidah said: He forbade red Al-Mayathir, and gold rings."
    },
    "ur": {
      "narrator": "عبیدہ سے روایت ہے کہ",
      "text": "انہوں نے سرخ زین اور سونے کی انگوٹھی سے منع فرمایا۔"
    },
