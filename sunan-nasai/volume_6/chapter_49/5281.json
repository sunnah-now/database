  "language": {
    "ar": {
      "text": "أَخْبَرَنَا قُتَيْبَةُ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا ابْنُ وَهْبٍ، ‏‏‏‏‏‏عَنْ يُونُسَ، ‏‏‏‏‏‏عَنِ الزُّهْرِيِّ، ‏‏‏‏‏‏عَنْ أَنَسٍ، ‏‏‏‏‏‏أَنَّ رَسُولَ اللَّهِ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ:‏‏‏‏ اتَّخَذَ خَاتَمًا مِنْ وَرِقٍ،‏‏‏‏ وَفَصُّهُ حَبَشِيٌّ ."
    },
    "en": {
      "narrator": "",
      "text": "It was narrated from Anas that: The Messenger of Allah [SAW] put on a ring of silver with an Ethiopian stone (Fass)."
    },
    "ur": {
      "narrator": "انس رضی اللہ عنہ سے روایت ہے کہ",
      "text": "رسول اللہ صلی اللہ علیہ وسلم نے چاندی کی ایک انگوٹھی بنوائی، اس کا نگینہ حبشہ کا بنا ہوا تھا۔"
    },
    "al": {
      "text": ""
    }
  }
