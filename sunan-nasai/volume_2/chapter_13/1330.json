          "text": "The Book of Forgetfulness (In Prayer)"
        },
        "ar": {
          "text": "كتاب السهو"
        },
        "ur": {
          "text": "نماز میں سہو کے احکام و مسائل"
        },
        "al": {
          "text": ""
        }
      }
