  },
  "language": {
    "ar": {
      "text": "أَخْبَرَنَا مُحَمَّدُ بْنُ آدَمَ،‏‏‏‏ عَنْ حَفْصٍ، ‏‏‏‏‏‏عَنِ الْأَعْمَشِ، ‏‏‏‏‏‏عَنْ إِبْرَاهِيمَ، ‏‏‏‏‏‏عَنْ عَلْقَمَةَ، ‏‏‏‏‏‏عَنْ عَبْدِ اللَّهِ، ‏‏‏‏‏‏أَنّ النَّبِيَّ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ:‏‏‏‏ سَلَّمَ،‏‏‏‏ ثُمَّ تَكَلَّمَ، ‏‏‏‏‏‏ثُمَّ سَجَدَ سَجْدَتَيِ السَّهْوِ ."
    },
    "en": {
      "narrator": "",
      "text": "It was narrated from 'Abdullah that: The Prophet (ﷺ) said the salam, then he spoke, then he performed two prostrations of forgetfulness."
    },
    "ur": {
      "narrator": "عبداللہ بن مسعود رضی اللہ عنہ سے روایت ہے کہ",
      "text": "نبی اکرم صلی اللہ علیہ وسلم نے سلام پھیرا، پھر آپ نے گفتگو کی، پھر سہو کے دو سجدے کیے۔"
    },
    "al": {
      "text": ""
    }
  }
