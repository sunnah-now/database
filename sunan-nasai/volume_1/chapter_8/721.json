  "language": {
    "ar": {
      "text": "أَخْبَرَنَا إِسْحَاقُ بْنُ إِبْرَاهِيمَ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ أَنْبَأَنَا النَّضْرُ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ أَنْبَأَنَا شُعْبَةُ، ‏‏‏‏‏‏عَنْ سُلَيْمَانَ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ سَمِعْتُ إِبْرَاهِيمَ، ‏‏‏‏‏‏عَنْ عَلْقَمَةَ، ‏‏‏‏‏‏وَالْأَسْوَدِ، ‏‏‏‏‏‏عَنْ عَبْدِ اللَّهِ، ‏‏‏‏‏‏فَذَكَرَ نَحْوَهُ."
    },
    "en": {
      "narrator": "",
      "text": "It was narrated that Sulaiman said: I heard Ibrahim (narrate) from 'Alqamah and Al-Aswad from 'Abdullah, and he narrated something similar."
    },
    "ur": {
      "narrator": "اس سند سے علقمہ اور اسود نے",
      "text": "عبداللہ بن مسعود رضی اللہ عنہ سے اسی جیسی حدیث ذکر کی ہے۔"
    },
    "al": {
      "text": ""
    }
  }
}