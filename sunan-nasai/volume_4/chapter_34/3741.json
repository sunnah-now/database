        "en": {
          "text": "The Book of Ar-Ruqba"
        },
        "ar": {
          "text": "كتاب الرقبى"
        },
        "ur": {
          "text": "رقبیٰ ( یعنی زندگی سے مشروط ہبہ ) کے احکام و مسائل"
        },
        "al": {
          "text": ""
        }
      }
    }
  },
  "language": {
    "ar": {
      "text": "أَخْبَرَنَا مُحَمَّدُ بْنُ بَشَّارٍ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا يَحْيَى، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا سُفْيَانُ، ‏‏‏‏‏‏عَنْ أَبِي الزُّبَيْرِ، ‏‏‏‏‏‏عَنْ طَاوُسٍ، ‏‏‏‏‏‏عَنِ ابْنِ عَبَّاسٍ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ الْعُمْرَى وَالرُّقْبَى سَوَاءٌ ."
    },
    "en": {
      "narrator": "",
      "text": "Sufyan narrated from Abu Az-Zubair, from Tawus, from Ibn 'Abbas, who said: 'Umra and Ruqba are the same."
    },
    "ur": {
      "narrator": "عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ",
      "text": "عمریٰ اور رقبیٰ دونوں برابر ہیں ( ان میں کچھ فرق نہیں ) ۔"
    },
    "al": {
      "text": ""
    }
  }
