  "language": {
    "ar": {
      "text": "أَخْبَرَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا مُحَمَّدٌ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا شُعْبَةُ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ سَمِعْتُ قَتَادَةَ يُحَدِّثُ، ‏‏‏‏‏‏عَنْ عَطَاءٍ، ‏‏‏‏‏‏عَنْ جَابِرٍ، ‏‏‏‏‏‏عَنِ النَّبِيِّ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ قَالَ:‏‏‏‏ الْعُمْرَى جَائِزَةٌ ."
    },
    "en": {
      "narrator": "",
      "text": "Shu'bah said: I heard Qatadah narrating from 'Ata', from Jabir that the Prophet said: 'Umra is permissible.'"
    },
    "ur": {
      "narrator": "جابر رضی الله عنہ سے روایت ہے کہ",
      "text": "نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”عمریٰ نافذ ہو گا“۔"
    },
    "al": {
      "text": ""
    }
  }
