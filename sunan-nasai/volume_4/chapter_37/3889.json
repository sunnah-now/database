  },
  "language": {
    "ar": {
      "text": "أَخْبَرَنَا مُحَمَّدٌ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ أَنْبَأَنَا حِبَّانُ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ أَنْبَأَنَا عَبْدُ اللَّهِ، ‏‏‏‏‏‏عَنْ حَمَّادِ بْنِ سَلَمَةَ، ‏‏‏‏‏‏عَنْ يُونُسَ، ‏‏‏‏‏‏عَنِ الْحَسَنِ، ‏‏‏‏‏‏أَنَّهُ:‏‏‏‏ كَرِهَ أَنْ يَسْتَأْجِرَ الرَّجُلَ حَتَّى يُعْلِمَهُ أَجْرَهُ ."
    },
    "en": {
      "narrator": "",
      "text": "It was narrated from Al-Hasan that he disliked to hire a man without telling him what his wages would be."
    },
    "ur": {
      "narrator": "حسن بصری سے روایت ہے کہ",
      "text": "وہ اس بات کو ناپسند کرتے تھے کہ کوئی آدمی کسی آدمی سے اس کی اجرت بتائے بغیر مزدوری کرائے۔"
    },
    "al": {
      "text": ""
    }
  }
