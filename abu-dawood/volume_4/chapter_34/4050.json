  "language": {
    "ar": {
      "text": "حَدَّثَنَا يَحْيَى بْنُ حَبِيبٍ، ‏‏‏‏‏‏حَدَّثَنَا رَوْحٌ، ‏‏‏‏‏‏حَدَّثَنَا هِشَامٌ، ‏‏‏‏‏‏عَنْ مُحَمَّدٍ، ‏‏‏‏‏‏عَنْ عَبِيدَةَ، ‏‏‏‏‏‏عَنْ عَلِيٍّ رَضِيَ اللَّهُ عَنْهُ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ نُهِيَ عَنْ مَيَاثِرِ الْأُرْجُوَانِ ."
    },
    "en": {
      "narrator": "Ali رضی اللہ عنہ said:",
      "text": "It is forbidden to use purple saddle-clothes."
    },
    "ur": {
      "narrator": "ہم سے یحییٰ بن حبیب نے بیان کیا، ہم سے راح نے بیان کیا، ہم سے ہشام نے بیان کیا، ان سے محمد صلی اللہ علیہ وسلم نے عبیدہ رضی اللہ عنہ سے, علی رضی اللہ عنہ کہتے ہیں",
      "text": "سرخ گدوں ( زین پوشوں ) سے منع کیا گیا ہے۔"
    },
    "al": {
      "text": ""
    }
